    "groupBy": ["TargetUserName", "MachineName"],
    "severity": { "default": "MEDIUM" },
    "filters": [],
    "recommendationTemplate": "User {{TargetUserName}} successfully logged in after failed attempts on machine {{MachineName}}."
  },
