{
  "S1": {
    "name": "Failed Logon",
    "eventIds": [4625],
    "aggregationWindowMinutes": 5,
    "groupBy": ["TargetUserName", "MachineName"],
    "threshold": 3,
    "severity": { "default": "MEDIUM" },
    "filters": [],
    "recommendationTemplate": "Check the machine {{MachineName}} and the user {{TargetUserName}}."
  },
  "S2": {
    "name": "Successful Logon after Failures",
    "eventIds": [4624, 4625],
