{
  "S1": {
    "name": "Single Failed Logon",
    "eventIds": [4625],
    "aggregationWindowMinutes": 5,
    "groupBy": ["MachineName", "TargetUserName"],
    "threshold": 1,
    "severity": { "default": "MEDIUM" },
    "recommendationTemplate": "Investigate failed logon for user {{TargetUserName}} on host {{MachineName}}."
  },

  "S2": {
    "name": "Brute Force Attempt",
    "eventIds": [4625],
    "aggregationWindowMinutes": 2,
    "groupBy": ["MachineName", "IpAddress"],
    "threshold": 3,
    "severity": { "default": "HIGH" },
    "recommendationTemplate": "Multiple failed logons detected from IP {{IpAddress}} on {{MachineName}}."
  },

  "S3": {
    "name": "Account Lockout",
    "eventIds": [4740],
    "aggregationWindowMinutes": 10,
    "groupBy": ["MachineName", "TargetUserName"],
    "threshold": 1,
    "severity": { "default": "HIGH" },
    "recommendationTemplate": "Account {{TargetUserName}} was locked out on {{MachineName}}."
  },

  "S4": {
    "name": "Suspicious NTLM Validation",
    "eventIds": [4776],
    "aggregationWindowMinutes": 5,
    "groupBy": ["MachineName", "Workstation"],
    "threshold": 1,
    "severity": { "default": "MEDIUM" },
    "recommendationTemplate": "NTLM validation attempt from workstation {{Workstation}}."
  },

  "S5": {
    "name": "Kerberos TGT Request",
    "eventIds": [4768],
    "aggregationWindowMinutes": 5,
    "groupBy": ["MachineName", "ClientName"],
    "threshold": 1,
    "severity": { "default": "LOW" },
    "recommendationTemplate": "Kerberos TGT requested by {{ClientName}}."
  },

  "S6": {
    "name": "Kerberos Service Ticket",
    "eventIds": [4769],
    "aggregationWindowMinutes": 5,
    "groupBy": ["MachineName", "ClientName"],
    "threshold": 1,
    "severity": { "default": "LOW" },
    "recommendationTemplate": "Service ticket requested by {{ClientName}} for {{ServiceName}}."
  },

  "S7": {
    "name": "Multiple Kerberos Tickets",
    "eventIds": [4769],
    "aggregationWindowMinutes": 2,
    "groupBy": ["MachineName", "ClientName"],
    "threshold": 2,
    "severity": { "default": "MEDIUM" },
    "recommendationTemplate": "Multiple Kerberos service tickets requested by {{ClientName}}."
  },

  "S21": {
    "name": "Repeated Signal",
    "meta": true,
    "aggregationWindowMinutes": 60,
    "groupBy": ["signalId", "MachineName"],
    "threshold": 2,
    "severity": { "default": "MEDIUM" },
    "recommendationTemplate": "Signal {{signalId}} occurred repeatedly on {{MachineName}}."
  },

  "S22": {
    "name": "New Event Type On Host",
    "meta": true,
    "aggregationWindowMinutes": 1440,
    "groupBy": ["MachineName", "EventId"],
    "severity": { "default": "MEDIUM" },
    "recommendationTemplate": "New event type {{EventId}} detected on {{MachineName}}."
  }
}